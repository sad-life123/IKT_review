{{#form}}
<div class="card p-3 mb-4 bg-light shadow-sm border-0">
    <form method="post" action="{{action_url}}" class="form-inline ikt-review-form">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="form-group mr-3">
            <label for="ikt-review-periodfrom" class="mr-2 font-weight-bold">{{str_periodfrom}}:</label>
            <input type="date" id="ikt-review-periodfrom" name="periodfrom" value="{{from_date}}" class="form-control">
        </div>

        <div class="form-group mr-3">
            <label for="ikt-review-periodto" class="mr-2 font-weight-bold">{{str_periodto}}:</label>
            <input type="date" id="ikt-review-periodto" name="periodto" value="{{to_date}}" class="form-control">
        </div>

        <button type="submit" name="action" value="run" class="btn btn-primary font-weight-bold shadow-sm">
            <i class="fa fa-play mr-1"></i> {{str_runreview}}
        </button>
    </form>
</div>
{{/form}}

{{#summary}}
<div class="card mb-4 border-left border-info shadow-sm">
    <div class="card-header bg-white font-weight-bold text-info border-0 pb-0">
        <h3>{{str_summary}}</h3>
        <div class="text-muted small">{{str_latestrun}}: # {{id}}</div>
    </div>
    <div class="card-body">
        <table class="table table-sm table-borderless m-0 summary-table">
            <tbody>
                {{#primary_indicators}}
                <tr>
                    <td class="font-weight-bold text-muted" style="width: 520px;">{{label}}</td>
                    <td class="font-weight-bold text-dark">{{value}}</td>
                </tr>
                {{/primary_indicators}}
                <tr class="table-info">
                    <td colspan="2" class="font-weight-bold">{{filled_note}}</td>
                </tr>
                {{#filled_indicators}}
                <tr>
                    <td class="font-weight-bold text-muted">{{label}}</td>
                    <td class="font-weight-bold text-dark">{{value}}</td>
                </tr>
                {{/filled_indicators}}
                {{#error}}
                <tr class="table-danger">
                    <td class="font-weight-bold text-danger">{{str_error}}:</td>
                    <td class="text-danger font-italic">{{error}}</td>
                </tr>
                {{/error}}
            </tbody>
        </table>
    </div>
</div>
{{/summary}}

{{#has_runs}}
<div class="runs-history-block mt-4">
    <h3 class="mb-3 text-secondary font-weight-bold">{{str_runs}}</h3>
    <div class="table-responsive bg-white rounded shadow-sm border">
        <table class="table table-striped table-hover m-0 custom-moodle-table">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>{{str_runstarted}}</th>
                    <th>{{str_periodfrom}}</th>
                    <th>{{str_periodto}}</th>
                    <th>{{str_status}}</th>
                    <th>{{str_duration}}</th>
                    <th>{{str_details}}</th>
                </tr>
            </thead>
            <tbody>
                {{#runs}}
                <tr>
                    <td><strong>{{id}}</strong></td>
                    <td>{{timestarted}}</td>
                    <td>{{periodfrom}}</td>
                    <td>{{periodto}}</td>
                    <td>
                        <span class="badge {{statusclass}}">{{status}}</span>
                    </td>
                    <td><i class="fa fa-clock-o text-muted mr-1"></i> {{duration}}</td>
                    <td>
                        {{#has_details}}
                        <a href="{{details_url}}" class="btn btn-sm btn-outline-secondary" data-ikt-review-run-details data-error-message="{{str_details_error}}">
                            <i class="fa fa-bar-chart mr-1"></i> {{str_details}}
                        </a>
                        {{/has_details}}
                    </td>
                </tr>
                {{/runs}}
            </tbody>
        </table>
    </div>
</div>
{{/has_runs}}
